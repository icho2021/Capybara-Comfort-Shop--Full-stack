// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

// Local SQLite datasource for Part 2 development.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// App users with role-based access control support.
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

// Store products that can be listed publicly and managed by admins.
model Product {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Float
  stock       Int
  category    String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Minimal order table included to satisfy Part 2 three-table requirement.
model Order {
  id              Int      @id @default(autoincrement())
  userId          Int
  status          String   @default("pending")
  totalAmount     Float
  shippingAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
